# .claudeignore — verhindert dass CC irrelevante Verzeichnisse in Context lädt
# Spart Tokens bei Repo-Scans, grep-Operationen und implizitem File-Discovery

# Quarantäne (MEGA73 + MEGA74 Cleanup)
_archiv/
docs/archiv-alte-sprints/

# Alte Masterplan-Generation (durch MEGA72/73/74 abgelöst)
masterplan-v2/

# Build-Artefakte / Dependencies
node_modules/
dist/
build/
.next/
.cache/

# Logs + Dumps
*.log
*.log.*
ki-statistik-dumps/
logs/
tmp/

# OS / Editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Sensible Env-Files (CC braucht nicht zu lesen)
.env
.env.local
.env.*.local

# Große generierte Files
package-lock.json
yarn.lock
pnpm-lock.yaml

# Test-Artefakte
coverage/
.nyc_output/
test-results/

# Backups
*.backup
*.bak
*.orig
