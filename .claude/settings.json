{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "PROVA Power-Setup MAX 03.05.2026 nachmittag — Auto-Permissions-Erweiterung post-MEGA-SKALIERUNG. Marcel-spezifische Overrides via .claude/settings.local.json. Pro-Sprint-Konvention: Marcel pre-authorisiert Bash(git push) damit autonome Sprints fluessig laufen — kritische Files (CLAUDE.md, package.json, netlify.toml, sw.js, supabase/migrations) bleiben unter ask-Schutz.",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npm run *)",
      "Bash(npm test:*)",
      "Bash(npm audit:*)",
      "Bash(npm install:*)",
      "Bash(npm update:*)",
      "Bash(npm ls:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(node --check:*)",
      "Bash(node --test:*)",
      "Bash(node scripts/*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git checkout:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(diff:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(bash scripts/*)",
      "Bash(bash -n:*)",
      "Bash(supabase functions deploy *)",
      "Bash(supabase functions list)",
      "Bash(supabase migration list)",
      "Bash(supabase db diff)",
      "Bash(netlify status)",
      "Bash(netlify env:list)",
      "Bash(netlify functions:list)",
      "Edit(/docs/**)",
      "Edit(/scripts/**)",
      "Edit(/tests/**)",
      "Edit(/lib/**)",
      "Edit(/netlify/functions/**)",
      "Edit(/supabase/functions/**)",
      "Edit(/src/**)",
      "Edit(/.claude/**)",
      "Edit(/email-templates/**)",
      "Edit(/*.html)",
      "Edit(/*.js)",
      "Edit(/*.css)",
      "Write(/docs/**)",
      "Write(/scripts/**)",
      "Write(/tests/**)",
      "Write(/lib/**)",
      "Write(/netlify/functions/**)",
      "Write(/supabase/functions/**)",
      "Write(/src/**)",
      "Write(/.claude/**)",
      "Write(/email-templates/**)",
      "Read(*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(npm uninstall:*)",
      "Bash(stripe:*)",
      "Bash(supabase db push)",
      "Bash(supabase functions invoke *)",
      "Bash(git reset:*)",
      "Edit(/supabase/migrations/**)",
      "Edit(/CLAUDE.md)",
      "Edit(/package.json)",
      "Edit(/netlify.toml)",
      "Edit(/sw.js)",
      "Edit(/_headers)",
      "Edit(/.gitignore)",
      "Write(/CLAUDE.md)",
      "Write(/package.json)",
      "Write(/netlify.toml)",
      "Write(/sw.js)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(supabase db reset)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "for f in $CLAUDE_FILE_PATHS; do case \"$f\" in *.js) node --check \"$f\" 2>&1 || echo \"[hook] SYNTAX-ERROR in $f\";; esac; done"
          },
          {
            "type": "command",
            "command": "for f in $CLAUDE_FILE_PATHS; do case \"$f\" in *netlify/functions/ki-*) grep -q 'prova-pseudo' \"$f\" || echo \"[hook] WARNING: KI-Function ohne prova-pseudo-Import: $f\";; esac; done"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"[console]::beep(800, 300)\""
          }
        ]
      }
    ]
  }
}
