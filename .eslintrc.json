{
  "env": {
    "browser": true,
    "es2015": true
  },
  "parserOptions": {
    "ecmaVersion": 2015,
    "sourceType": "script"
  },
  "rules": {
    "no-undef": "off",
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["netlify/functions/**/*.js"],
      "env": {
        "node": true,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022
      }
    }
  ],
  "ignorePatterns": [
    "marked.min.js",
    "marked_min.js",
    "build-compat.js",
    "node_modules/"
  ]
}
