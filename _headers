/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://identity.netlify.com https://api.netlify.com https://api.airtable.com https://api.openai.com https://api.stripe.com https://api.pdfmonkey.io https://hook.eu1.make.com https://hook.eu2.make.com wss:; frame-src https://js.stripe.com; media-src 'self' blob:; worker-src 'self' blob:

# CORS wird vollständig von cors-helper.js in jeder Function gesetzt (inkl. Origin-Whitelist)

# HTML: immer aktuell vom Server holen
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# SW: niemals cachen (Browser muss immer neue Version erkennen)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# JS: kein langer Cache — nach jedem Deploy frisch laden
# Netlify CDN würde sonst 1 Jahr cachen
/*.js
  Cache-Control: no-cache, must-revalidate

# CSS: kein langer Cache
/*.css
  Cache-Control: no-cache, must-revalidate

# Icons/Bilder: 7 Tage Cache (ändern sich selten)
/*.png
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800

# manifest.json: kurz cachen
/manifest.json
  Cache-Control: no-cache, must-revalidate
