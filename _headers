/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=self, microphone=self, geolocation=self
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://identity.netlify.com https://api.netlify.com https://api.airtable.com https://api.openai.com https://api.stripe.com https://api.pdfmonkey.io https://hook.eu1.make.com https://hook.eu2.make.com wss:; frame-src https://js.stripe.com; media-src 'self' blob:; worker-src 'self' blob:

/.netlify/functions/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, PUT, PATCH, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-PROVA-Secret

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# S-SICHER 4.9: Statische Assets strikt auf prova-systems.de beschränken.
# Funktional identisch zum Netlify-Default (kein Cross-Origin-Leak),
# aber dokumentiert explizit die Absicht.
# /.netlify/functions/* bleibt unverändert (CORS-Handling in Functions selbst,
# siehe netlify/functions/lib/cors-helper.js).
/*.js
  Access-Control-Allow-Origin: https://prova-systems.de

/*.css
  Access-Control-Allow-Origin: https://prova-systems.de

/*.png
  Access-Control-Allow-Origin: https://prova-systems.de

/*.jpg
  Access-Control-Allow-Origin: https://prova-systems.de
