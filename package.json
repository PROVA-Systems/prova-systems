{
  "name": "prova-deploy",
  "private": true,
  "dependencies": {
    "@sentry/browser": "^10.51.0",
    "@sentry/node": "^10.51.0",
    "@supabase/supabase-js": "^2.105.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.0",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.7",
    "stripe": "^22.1.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0"
  },
  "scripts": {
    "test": "bash prova-check.sh",
    "predeploy": "bash prova-check.sh",
    "check": "bash prova-check.sh",
    "verify-stripe": "node scripts/verify-stripe-setup.js",
    "test-checkouts": "node scripts/test-stripe-checkout.js",
    "test-webhook": "node scripts/verify-stripe-webhook.js",
    "stripe-status": "node scripts/stripe-webhook-status.js",
    "stripe-replay": "node scripts/stripe-webhook-replay.js",
    "test:stripe": "node --test tests/stripe/stripe-webhook.test.js tests/stripe/stripe-prices.test.js tests/stripe/founding-pilot.test.js",
    "test:schemas": "node --test tests/schemas/schemas.test.js tests/schemas/beratung.test.js tests/schemas/baubegleitung.test.js",
    "test:all": "node --test tests/schemas/*.test.js tests/stripe/*.test.js tests/auth/*.test.js",
    "test:stripe-suite": "node scripts/stripe-test-suite.js",
    "test:multitenant": "node tests/multitenant-isolation/setup.js && node --test tests/multitenant-isolation/isolation.test.js",
    "test:emails": "node scripts/email-render-check.js"
  }
}
