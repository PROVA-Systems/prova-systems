# PROVA Systems — Git Line Endings
# Verhindert CRLF-Probleme auf Windows-Entwicklungsrechnern
# Netlify (Linux) erwartet LF — dieses File erzwingt das für alle Commits

*.js        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.svg       text eol=lf

# Binärdateien — keine Konvertierung
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary