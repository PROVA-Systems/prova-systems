<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title> MA-2026-0042-3</title>
<style>
  /* PROVA MAHNUNG · DIN 5008 + Design-System v1.0
     Für F-06 (Stufe 1) · F-07 (Stufe 2) · F-08 (Stufe 3)
     Mahnstufe steuert Farbgebung (blau/orange/rot) */
  @page { size: A4; margin: 0; }
  html, body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, sans-serif;
    font-size: 10.5pt; line-height: 1.55; color: #1a1f2e; -webkit-font-smoothing: antialiased; }
  .page { width: 210mm; min-height: 297mm; padding: 0; background: #fff; position: relative;
    page-break-after: always; }
  .page:last-child { page-break-after: auto; }

  /* BRIEFKOPF */
  .briefkopf { padding: 20mm 20mm 0 20mm; border-bottom: 0.5pt solid #cbd5e1; padding-bottom: 4mm; }
  .briefkopf-zeile { display: flex; justify-content: space-between; align-items: flex-start; }
  .briefkopf-sv-name { font-size: 14pt; font-weight: 700; color: #1a3a6b; line-height: 1.2; letter-spacing: -0.01em; }
  .briefkopf-sv-untertitel { font-size: 9pt; color: #64748b; margin-top: 1mm; line-height: 1.4; }
  .briefkopf-kontakt { font-size: 8.5pt; color: #64748b; text-align: right; line-height: 1.5; }

  .absender-mini { margin: 5mm 20mm 0 20mm; font-size: 7pt; color: #94a3b8;
    border-bottom: 0.3pt solid #cbd5e1; padding-bottom: 1mm; }

  /* DIN 5008 ADRESSFELD */
  .adressfeld { margin: 3mm 20mm 0 20mm; width: 85mm; min-height: 35mm; font-size: 11pt; line-height: 1.5; }
  .adressfeld-name { font-weight: 600; }

  /* BEZUGSZEILE */
  .bezugszeile { position: absolute; top: 70mm; right: 20mm; width: 70mm; font-size: 9pt; }
  .bezugszeile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5mm 4mm; }
  .bezugszeile-label { color: #64748b; font-size: 7.5pt; text-transform: uppercase; letter-spacing: 0.04em; }
  .bezugszeile-wert { font-weight: 500; color: #1a1f2e; font-family: 'JetBrains Mono', monospace; font-size: 9pt; }

  /* MAHNUNG-HEADLINE (prominent statt dezentem Badge) */
  .mahnung-headline-wrapper { margin: 25mm 20mm 0 20mm; padding: 6mm 8mm;
    border-radius: 2mm; background: #dbeafe; border-left: 5pt solid #1e40af; }
  .mahnung-headline-wrapper.stufe-2 { background: #fff7ed; border-left-color: #ea580c; }
  .mahnung-headline-wrapper.stufe-3 { background: #fef2f2; border-left-color: #b91c1c; }
  .mahnung-stufe-label { font-size: 9.5pt; font-weight: 700; color: #1e40af;
    text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 1mm; }
  .mahnung-headline-wrapper.stufe-2 .mahnung-stufe-label { color: #c2410c; }
  .mahnung-headline-wrapper.stufe-3 .mahnung-stufe-label { color: #991b1b; }
  .mahnung-headline { font-size: 24pt; font-weight: 700; color: #1a3a6b;
    line-height: 1.1; letter-spacing: -0.02em; }
  .mahnung-headline-wrapper.stufe-2 .mahnung-headline { color: #c2410c; }
  .mahnung-headline-wrapper.stufe-3 .mahnung-headline { color: #991b1b; }
  .mahnung-untertitel { font-size: 11pt; color: #64748b; margin-top: 2mm; line-height: 1.4; }

  /* BRIEFTEXT */
  .anrede { margin: 8mm 20mm 0 20mm; font-size: 10.5pt; }
  .brieftext { margin: 4mm 20mm 0 20mm; font-size: 10.5pt; text-align: justify;
    page-break-inside: avoid; break-inside: avoid; }
  .brieftext p { margin: 0 0 3mm 0; }

  /* RECHNUNGSTABELLE — prominent, mit fetten Summen */
  .mahntabelle-wrapper { margin: 5mm 20mm 0 20mm; page-break-inside: avoid; break-inside: avoid; }
  table.mahntabelle { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
  table.mahntabelle thead { background: #f1f5f9; border-bottom: 1.5pt solid #1a3a6b; }
  table.mahntabelle thead th { padding: 2.5mm 2mm; text-align: left; font-size: 8.5pt;
    text-transform: uppercase; letter-spacing: 0.04em; color: #1a3a6b; font-weight: 600; }
  table.mahntabelle thead th.zahl { text-align: right; }
  table.mahntabelle tbody tr { border-bottom: 0.3pt solid #e2e8f0; }
  table.mahntabelle td { padding: 2.5mm 2mm; vertical-align: top; }
  table.mahntabelle td.zahl { text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 9.5pt; }
  table.mahntabelle td.gesamt-betrag { font-weight: 600; }
  table.mahntabelle tr.summe { border-top: 1.5pt solid #1a3a6b;
    background: linear-gradient(90deg, #f1f5f9 0%, #fef3c7 100%); }
  table.mahntabelle tr.summe td { padding: 3mm 2mm; font-weight: 700; color: #1a3a6b; font-size: 10.5pt; }

  /* FRIST-BOX (prominent, eskalierend) */
  .frist-box { margin: 6mm 20mm 0 20mm; padding: 5mm 6mm; border-left: 4pt solid #1a3a6b;
    background: #f8fafc; font-size: 11pt; line-height: 1.55;
    page-break-inside: avoid; break-inside: avoid; }
  .frist-box.stufe-2 { border-left-color: #ea580c; background: #fff7ed; }
  .frist-box.stufe-3 { border-left-color: #b91c1c; background: #fef2f2; }
  .frist-box-titel { font-weight: 700; color: #1a3a6b; margin-bottom: 2mm; font-size: 10pt;
    text-transform: uppercase; letter-spacing: 0.06em; }
  .frist-box.stufe-2 .frist-box-titel { color: #c2410c; }
  .frist-box.stufe-3 .frist-box-titel { color: #991b1b; }
  .frist-datum { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 12pt; }

  /* ZAHLUNGSDATEN-BOX (prominent auf Mahnung!) */
  .zahlungsdaten { margin: 6mm 20mm 0 20mm; padding: 4mm 5mm;
    background: #f1f5f9; border-radius: 2mm; font-size: 10pt; line-height: 1.6;
    page-break-inside: avoid; break-inside: avoid; }
  .zahlungsdaten-titel { font-weight: 700; color: #1a3a6b; font-size: 9.5pt;
    text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2mm; }
  .zahlungsdaten-zeile { display: flex; gap: 4mm; margin-bottom: 0.8mm; }
  .zahlungsdaten-label { color: #64748b; min-width: 35mm; }
  .zahlungsdaten-wert { font-family: 'JetBrains Mono', monospace; color: #1a1f2e; font-weight: 500; }

  /* SCHLUSS + GRUSS + UNTERSCHRIFT */
  .schluss { margin: 6mm 20mm 0 20mm; font-size: 10.5pt; text-align: justify;
    page-break-inside: avoid; break-inside: avoid; }
  .gruss { margin: 5mm 20mm 0 20mm; font-size: 10.5pt;
    page-break-inside: avoid; break-inside: avoid; page-break-after: avoid; break-after: avoid; }
  .unterschrift { margin: 12mm 20mm 0 20mm; font-size: 10.5pt;
    page-break-inside: avoid; break-inside: avoid; page-break-before: avoid; break-before: avoid; }
  .unterschrift-name { font-weight: 600; color: #1a3a6b; }
  .unterschrift-funktion { font-size: 9pt; color: #64748b; }

  .anlagen { margin: 8mm 20mm 0 20mm; font-size: 9.5pt;
    page-break-inside: avoid; break-inside: avoid; }
  .anlagen-titel { font-weight: 600; color: #1a3a6b; margin-bottom: 1mm; }

  .dsgvo-hinweis { margin: 8mm 20mm 0 20mm; font-size: 7pt; color: #94a3b8;
    line-height: 1.4; font-style: italic;
    page-break-inside: avoid; break-inside: avoid; }

  .pflichtangaben { margin: 12mm 20mm 0 20mm; padding-top: 4mm; border-top: 1pt solid #cbd5e1;
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 5mm; font-size: 7.5pt;
